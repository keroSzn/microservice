APP_NAME="Torku Ürün & Reklam API"
ENVIRONMENT="production"

# CORS – Docker kurulumunda nginx aynı origin'den sunar, sadece 80 portuna izin yeter.
# Geliştirme ortamı için: http://localhost:5173
CORS_ORIGINS="http://localhost,http://localhost:80"

# DB – Docker Compose'da servis adı "postgres" olduğu için host adı "postgres"
# Yerel geliştirme için: postgresql+psycopg://postgres:postgres@localhost:5432/reklam_proje
DATABASE_URL="postgresql+psycopg://postgres:postgres@postgres:5432/reklam_proje"

# Auth – ÜRETİMDE MUTLAKA GÜÇLENDİR
JWT_SECRET="change-me-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin bootstrap (ilk çalıştırmada yoksa oluşturulur) – ÜRETİMDE DEĞİŞTİR
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin12345"

# Media – Docker container içindeki yol (volume ile kalıcı)
MEDIA_DIR="/app/media"
MAX_UPLOAD_MB=250
ALLOWED_VIDEO_MIME_TYPES="video/mp4,video/webm"
ALLOWED_IMAGE_MIME_TYPES="image/jpeg,image/png,image/webp,image/gif"
MAX_IMAGE_UPLOAD_MB=10
