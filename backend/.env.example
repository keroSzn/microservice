APP_NAME="Torku Ürün & Reklam API"
ENVIRONMENT="dev"

# CORS
CORS_ORIGINS="http://localhost:5173"

# DB
# Örnek Postgres (Docker compose ile):
# postgresql+psycopg://postgres:postgres@localhost:5432/reklam_proje
DATABASE_URL="sqlite:///./dev.db"

# Auth
JWT_SECRET="change-me"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin bootstrap (ilk çalıştırmada yoksa oluşturulur)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin12345"

# Media
MEDIA_DIR="./media"
MAX_UPLOAD_MB=250
ALLOWED_VIDEO_MIME_TYPES="video/mp4,video/webm"
